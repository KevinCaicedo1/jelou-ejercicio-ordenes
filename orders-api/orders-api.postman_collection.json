    },
    {
      "key": "productId",
      "value": "1"
    },
    {
      "key": "orderId",
      "value": "1"
    },
    {
      "key": "customerId",
      "value": "1"
    },
    {
      "key": "idempotencyKey",
      "value": "2f6c5a37-9677-4d95-8ed6-4f1d8a57aa11"
